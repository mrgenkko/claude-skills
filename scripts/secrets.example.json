{
  "mcp_servers": [
    {
      "name": "gcloud-proyecto-a",
      "type": "gcloud",
      "project": "mi-proyecto-gcp",
      "region": "us-east4",
      "workdir": "/home/TU_USUARIO/mi-proyecto",
      "account": "sa@mi-proyecto-gcp.iam.gserviceaccount.com",
      "key_file": null
    },
    {
      "name": "gcloud-proyecto-b",
      "type": "gcloud",
      "project": "mi-otro-proyecto-gcp",
      "region": "us-east4",
      "workdir": "/home/TU_USUARIO/mi-otro-proyecto",
      "account": "sa@mi-otro-proyecto-gcp.iam.gserviceaccount.com",
      "key_file": "/home/TU_USUARIO/keys/mi-otro-proyecto/sa.json",
      "config_dir": "/home/TU_USUARIO/.config/gcloud-proyecto-b"
    },
    {
      "name": "postgres-mi-bd",
      "type": "postgres",
      "host": "TU_HOST_BD",
      "port": 5432,
      "db": "mi_base_de_datos",
      "user": "mi_usuario",
      "password": "mi_contraseña"
    },
    {
      "name": "ssh-mi-servidor",
      "type": "ssh",
      "host": "192.168.1.100",
      "port": 22,
      "user": "ubuntu",
      "key_file": "/home/TU_USUARIO/.ssh/id_rsa",
      "password": null,
      "sudo_password": null
    },
    {
      "name": "redis-mi-cache",
      "type": "redis",
      "host": "TU_HOST_REDIS",
      "port": 6379,
      "db": 0,
      "password": null,
      "allow_flush": false
    },
    {
      "name": "gh-mi-org",
      "type": "gh",
      "token": "ghp_xxx_o_github_pat_xxx",
      "owner": "mi-org",
      "allow_write": false
    },
    {
      "name": "obsidian",
      "type": "obsidian",
      "vault_path": "/home/TU_USUARIO/ObsidianVault"
    },
    {
      "name": "obsidian-a2a",
      "type": "obsidian-a2a",
      "gateway_url": "http://localhost:7415",
      "gateway_key": "a2a_<KEY>",
      "vault_path": "/home/TU_USUARIO/ObsidianVault"
    },
    {
      "name": "webprobe",
      "type": "webprobe",
      "browser": "chromium",
      "headless": true,
      "allow_headed": true,
      "max_tabs": 8,
      "tab_idle_timeout": 600,
      "browser_idle_timeout": 1800,
      "timeout_ms": 60000
    }
  ]
}
